# Choose one provider: workers_ai, openai, qwen, or deepseek.
# workers_ai uses Cloudflare's built-in AI binding (no API key needed in production).
# For local dev, set to deepseek/openai/qwen and provide the matching API key below.
AI_PROVIDER=workers_ai

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Qwen / Alibaba Cloud Model Studio OpenAI-compatible Chat Completions
QWEN_API_KEY=
# DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek OpenAI-compatible Chat Completions
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
